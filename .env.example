# Supabase (vanilla frontend)
# Estas claves van en js/shared.js
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Backend (Node.js/Express — deprecated)
# Solo necesario si se revive el backend
JWT_SECRET=your-jwt-secret-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quasar
DB_USER=postgres
DB_PASSWORD=postgres

# Next.js frontend (progresivo)
# Archivo: frontend/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# HenrikDev API (VALORANT Tracker)
# Opcional — si se migra a proxy backend
HENRIKDEV_API_KEY=your-henrikdev-key-here
